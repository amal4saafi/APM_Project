# ============================================================
# APM TOPNET — Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs.
# ============================================================

# --- Base de données ---
DB_NAME=apm_db
DB_USER=apm_user
DB_PASSWORD=apm_pass
DB_HOST=db
DB_PORT=3306

# --- Django ---
SECRET_KEY=changez-moi-en-production
DEBUG=False
SITE_BASE_URL=https://apm.topnet.tn

# --- Email (mot de passe oublié) ---
# En développement, laissez EMAIL_BACKEND vide → les emails s'affichent dans la console.
# En production, utilisez le backend SMTP et renseignez les champs ci-dessous.

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-compte@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
DEFAULT_FROM_EMAIL=noreply@topnet.tn

# --- Autres ---
# Pour Outlook / Office 365 :
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
